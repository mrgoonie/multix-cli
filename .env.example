# ===== Provider API keys =====
GEMINI_API_KEY=
OPENROUTER_API_KEY=
MINIMAX_API_KEY=
LEONARDO_API_KEY=
BYTEPLUS_API_KEY=
# Fallback for BYTEPLUS_API_KEY (Volcengine ARK shared name)
ARK_API_KEY=

# ===== Output / CLI behavior =====
# Override default output dir (./multix-output)
MULTIX_OUTPUT_DIR=
# Set to "1" to disable loading ~/.multix/.env
MULTIX_DISABLE_HOME_ENV=
# Set to "1" to disable ANSI colors
NO_COLOR=

# ===== Gemini model overrides =====
GEMINI_MODEL=
MULTIMODAL_MODEL=
IMAGE_GEN_MODEL=
GEMINI_IMAGE_GEN_MODEL=
VIDEO_GEN_MODEL=
GEMINI_TTS_MODEL=
TTS_MODEL=

# ===== OpenRouter model overrides =====
OPENROUTER_IMAGE_MODEL=
OPENROUTER_VIDEO_MODEL=
# Comma-separated fallback model ids
OPENROUTER_FALLBACK_MODELS=

# ===== MiniMax model overrides =====
MINIMAX_IMAGE_MODEL=
MINIMAX_VIDEO_MODEL=
MINIMAX_SPEECH_MODEL=
MINIMAX_MUSIC_MODEL=

# ===== Leonardo model overrides =====
LEONARDO_DEFAULT_MODEL=
LEONARDO_VIDEO_MODEL=

# ===== BytePlus model overrides =====
BYTEPLUS_IMAGE_MODEL=
BYTEPLUS_VIDEO_MODEL=
BYTEPLUS_VIDEO_PARAMS_MODE=
